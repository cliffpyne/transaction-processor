<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SMS Rescue"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-rescues failed bank transactions by forwarding SMS to the server."
            android:textSize="13sp"
            android:paddingBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server URL"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/serverUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:hint="https://processor.eleganskyboda.com"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Migration token"
            android:textStyle="bold"
            android:paddingTop="8dp"/>
        <EditText
            android:id="@+id/token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textVisiblePassword"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sender whitelist (comma-separated substrings)"
            android:textStyle="bold"
            android:paddingTop="8dp"/>
        <EditText
            android:id="@+id/senders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="NMB,CRDB,NMBBANK,CRDBBANK"/>

        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save settings"
            android:layout_marginTop="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22000000"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/permsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="checking SMS permissions…"
            android:paddingBottom="4dp"/>
        <Button
            android:id="@+id/grantPermsBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant SMS permissions"/>

        <TextView
            android:id="@+id/defaultSmsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="checking default SMS role…"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"/>
        <Button
            android:id="@+id/becomeDefaultBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set as default SMS app"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22000000"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="queued: 0  ·  rescued: 0  ·  flagged: 0"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/drainNowBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Drain queue now"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/importInboxBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import inbox from last Saturday"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</ScrollView>
